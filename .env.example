# Copy the vars you need into .env.local (gitignored). Never commit real values.

# Supabase Postgres connection strings (Project Settings -> Database in the
# Supabase dashboard). DATABASE_URL is the pooled connection (port 6543,
# pgbouncer transaction mode) used by the app at runtime — see src/lib/prisma.ts.
# DIRECT_URL is the direct connection (port 5432) used only for running
# migrations — see prisma.config.ts.
DATABASE_URL="postgresql://postgres.your-project:your-password@your-project-pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project:your-password@your-project.supabase.com:5432/postgres"

# Password required to use /admin (post/delete reports and Mr. Market readings).
ADMIN_PASSWORD=choose-a-password

# Used by the admin Sandbox tab to call Claude directly with the engine's own
# .md files as the system prompt. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key

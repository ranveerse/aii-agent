// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql" // swap to "postgresql" for the later Supabase migration
  // Connection URL lives in prisma.config.ts (CLI/migrate) and src/lib/prisma.ts
  // (runtime client via a driver adapter) — Prisma 7 no longer reads `url` here.
}

// One row per stock analysis. Mirrors docs/ANALYSIS_ENGINE.md's Phase 3 output
// JSON schema — see `raw` below. Analysis logic itself lives only in that doc;
// this table just persists whatever JSON it produces.
model Report {
  id          Int    @id @default(autoincrement())
  ticker      String @unique @db.VarChar(10) // always uppercased at the API layer, see src/lib/validation
  companyName String @map("company_name") @db.VarChar(120)
  // ^ Not part of ANALYSIS_ENGINE.md's output — the engine has no "name" field.
  // Supplied by whoever submits the report, alongside the JSON, purely for display.

  // Promoted for sort/filter/list rendering (Today/Screener/Analysis tabs).
  // Nullable: the engine may legitimately return a non-numeric "N/A – insufficient
  // data" string for any of these (see ANALYSIS_ENGINE.md's Data Input Mode rules).
  // When it does, the typed column stays null and the real value lives only in `raw`
  // — never coerce/guess a number here, that would violate the engine's own rule.
  currentPrice              Float?  @map("current_price")
  investmentGrade           String? @map("investment_grade") @db.VarChar(40)
  compositeScore            Int?    @map("composite_score")
  adjustedMarginOfSafetyPct Float?  @map("adjusted_margin_of_safety_percentage")
  piotroskiFScore           Int?    @map("piotroski_f_score")
  altmanZScore              Float?  @map("altman_z_score")
  roic                      Float?
  wacc                      Float?
  intrinsicValuePerShare    Float?  @map("intrinsic_value_per_share")
  epvPerShare               Float?  @map("epv_per_share")

  // Full, verbatim Phase-3 JSON payload from ANALYSIS_ENGINE.md — the source of
  // truth. Every typed column above is a denormalized copy of a value in here,
  // solely so SQL can sort/filter without parsing JSON per row.
  raw Json @map("raw_report")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([investmentGrade])
  @@index([compositeScore])
  @@map("reports")
}

// One row per Mr. Market Index computation. Mirrors docs/MR_MARKET_INDEX_SPEC.md's
// output JSON schema. The composite-score formula itself lives only in
// src/lib/mrMarket.ts (which implements that spec) — this table just persists results.
model MrMarketReading {
  id             Int      @id @default(autoincrement())
  asOf           DateTime @unique @map("as_of") @db.Date
  compositeScore Float    @map("composite_score")
  zone           String   @db.VarChar(20) // Deep Value | Fearful | Neutral | Greedy | Euphoric
  reading        String   @db.Text

  // The 5-element components array (name, raw, percentile, oriented_score, weight)
  // exactly as documented in MR_MARKET_INDEX_SPEC.md's output JSON. Stored as JSON,
  // not a child table, because it's always read/written as one unit per reading.
  components Json

  createdAt DateTime @default(now()) @map("created_at")

  @@map("mr_market_readings")
}

// One row per "Request a stock" submission from the Analyze tab. Just a log of
// interest — no analysis is triggered by it (that pipeline doesn't exist yet).
model StockRequest {
  id        Int      @id @default(autoincrement())
  ticker    String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticker])
  @@map("stock_requests")
}

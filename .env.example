# Copy the vars you need into .env.local (gitignored). Never commit real values.

# Local MySQL connection (discrete parts, not a single URL — see src/lib/prisma.ts).
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database

# Password required to use /admin (post/delete reports and Mr. Market readings).
ADMIN_PASSWORD=choose-a-password
